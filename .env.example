# The endpoint of your running Ascend Next.js Web app API (default is http://localhost:3000/api)
PORTFOLIO_API_URL=http://localhost:3000/api

# A secure random token used for API requests authentication. 
# CRITICAL: This MUST match the MCP_API_KEY configured in the main Ascend App's .env file.
MCP_API_KEY=your_secure_random_string_here

# MCP communication mechanism: 'stdio' or 'sse' (default: stdio)
MCP_TRANSPORT=stdio

# The HTTP port utilized when running in 'sse' mode (default is 3001)
PORT=3001
